  "onRowSelected": "{{\n(async () => {\n\tawait storeValue('activeArticleId', Table2.selectedRow.article_id);\n\tresetWidget('sel_article', true);\n\tstoreValue('_trigger', Date.now());\n\n\tawait UTJS.onArticleSelect();\n\n\tconst summary = Table2.selectedRow.concern_summary || '';\n\tconst hasBomConcern = summary.includes('BOM Update: ');\n\n\tif (hasBomConcern) {\n\t\tawait getBOMDeltaForDivision.run({\n\t\t\tarticleId: Table2.selectedRow.article_id\n\t\t});\n\t\tshowModal(\"mdl_revisionDelta\");\n\t} else {\n\t\tshowAlert(\"Ada concern non-BOM untuk artikel ini — cek tabel concern di bawah.\", \"info\");\n\t}\n})()\n}}",
