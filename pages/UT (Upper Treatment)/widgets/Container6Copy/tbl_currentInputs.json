  "tableData": "{{\n  (function() {\n    const _ = appsmith.store._trigger;\n    if (!UTJS._editWipId) return [];\n\n    const wips = getWIPList.data || [];\n    const wip = wips.find(function(w) { return w.id === UTJS._editWipId; });\n    if (!wip) return [];\n\n    const inputs = typeof wip.inputs === 'string' ? JSON.parse(wip.inputs) : (wip.inputs || []);\n    const pool = getAvailablePool.data || [];\n\n    let current = inputs.map(function(i) {\n      const poolItem = pool.find(function(p) {\n        return p.kind === i.kind && p.ref === i.ref;\n      });\n      return {\n        kind: i.kind,\n        ref: i.ref,\n        label: i.label || (i.kind + ':' + i.ref),\n        part_number: poolItem ? poolItem.part_number : (i.kind === 'WIP' ? '#' + i.ref : '—'),\n        part_name: poolItem ? poolItem.part_name : (i.label || '—')\n      };\n    });\n\n    UTJS._pendingAdd.forEach(function(item) {\n      const alreadyIn = current.some(function(c) {\n        return c.kind === item.kind && c.ref === item.ref;\n      });\n      if (!alreadyIn) {\n        const poolItem = pool.find(function(p) {\n          return p.kind === item.kind && p.ref === item.ref;\n        });\n        current.push({\n          kind: item.kind,\n          ref: item.ref,\n          label: item.label,\n          part_number: poolItem ? poolItem.part_number : String(item.ref),\n          part_name: poolItem ? poolItem.part_name : (item.label || String(item.ref))\n        });\n      }\n    });\n\n    current = current.filter(function(c) {\n      return !UTJS._pendingRemove.some(function(r) {\n        return r.kind === c.kind && r.ref === c.ref;\n      });\n    });\n\n    return current;\n  })()\n}}",
