  "tableData": "{{\n  (function() {\n    const _ = appsmith.store._trigger;\n    const pool = getAvailablePool.data || [];\n\n    let available = pool\n      .filter(function(p) { return !p.is_current_wip; })\n      .filter(function(p) {\n        return !UTJS._pendingAdd.some(function(a) {\n          return a.kind === p.kind && a.ref === p.ref;\n        });\n      });\n\n    UTJS._pendingRemove.forEach(function(r) {\n      const alreadyIn = available.some(function(a) {\n        return a.kind === r.kind && a.ref === r.ref;\n      });\n      if (!alreadyIn) {\n        const poolItem = pool.find(function(p) {\n          return p.kind === r.kind && p.ref === r.ref;\n        });\n        available.push({\n          kind: r.kind,\n          ref: r.ref,\n          code: poolItem ? poolItem.code : String(r.ref),\n          part_number: poolItem ? poolItem.part_number : String(r.ref),\n          part_name: poolItem ? poolItem.part_name : (r.label || String(r.ref)),\n          label: poolItem ? poolItem.label : (r.label || String(r.ref)),\n          is_current_wip: false\n        });\n      }\n    });\n\n    return available;\n  })()\n}}",
